<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="ButtonMainScreen" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginTop">@dimen/btn_main_margin_top</item>
        <item name="backgroundTint">@color/YP_White</item>
        <item name="textAllCaps">false</item>
        <item name="android:textColor">@color/YP_Black</item>
        <item name="cornerRadius">@dimen/btn_corner_radius</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">@dimen/ic_padding_right</item>
        <item name="iconTint">@color/YP_Black</item>
    </style>

    <style name="UnelevatedBtn" parent="Widget.MaterialComponents.Button.UnelevatedButton" />

    <style name="TextViewTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
    </style>

    <style name="FrameLayoutSettings">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingVertical">@dimen/padding_vertical_settings</item>
        <item name="android:paddingRight">@dimen/padding_right_settings</item>
    </style>

    <style name="TextViewSettings">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">start|center_vertical</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
    </style>

    <style name="ImageViewSettings">
        <item name="android:layout_width">@dimen/ic_size_default</item>
        <item name="android:layout_height">@dimen/ic_size_default</item>
        <item name="android:layout_gravity">end|center_vertical</item>
        <item name="android:scaleType">centerCrop</item>
    </style>


    <style name="TextViewTrackFields">
        <item name="android:textAppearance">@style/YSRegular13</item>
        <item name="android:textColor">@color/YP_Text_Gray</item>
        <item name="layout_constraintHorizontal_bias">0</item>
        <item name="layout_constraintHeight_min">32dp</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="TextViewTrackFieldsData">
        <item name="android:textAppearance">@style/YSRegular13</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:gravity">end</item>
        <item name="android:ellipsize">end</item>
        <item name="android:lines">1</item>
        <item name="android:layout_marginStart">8dp</item>
    </style>

    <style name="Placeholder">
        <item name="android:orientation">vertical</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/placeholder_margin_top</item>
        <item name="android:paddingHorizontal">@dimen/placeholder_padding_horizontal</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="PlaceholderImage">
        <item name="android:layout_width">@dimen/placeholder_image_size</item>
        <item name="android:layout_height">@dimen/placeholder_image_size</item>
        <item name="android:layout_marginBottom">@dimen/placeholder_image_margin_bottom</item>
        <item name="android:scaleType">centerCrop</item>
    </style>

    <style name="PlaceholderTextView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">@dimen/placeholder_text_margin_bottom</item>
        <item name="android:gravity">center_horizontal</item>
        <item name="android:textAppearance">@style/YSMedium19</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
    </style>

    <style name="PlaceholderButton" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">16dp</item>
        <item name="backgroundTint">?attr/colorOnPrimary</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:layout_marginTop">24dp</item>
        <item name="textAllCaps">false</item>
        <item name="android:textAppearance">@style/YSMedium14</item>
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="cornerRadius">54dp</item>
    </style>

    <style name="TextInputLayoutPlaylistCreation" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="android:gravity">center_vertical</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxStrokeColor">@color/input_outline_selector</item>
        <item name="hintTextColor">@color/input_hint_selector</item>
        <item name="hintAnimationEnabled">true</item>

    </style>

    <style name="EditTextPlaylistCreation">
        <item name="android:inputType">text</item>
        <item name="android:autofillHints">no</item>
        <item name="android:maxLength">60</item>
        <item name="singleLine">true</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
    </style>

</resources>