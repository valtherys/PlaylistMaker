<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".ui.medialibrary.favorite_tracks.fragment.FavoriteTracksFragment">

    <LinearLayout
        android:visibility="gone"
        android:id="@+id/ll_placeholder"
        style="@style/Placeholder"
>

        <ImageView
            android:id="@+id/iv_placeholder"
            style="@style/PlaceholderImage"
            android:src="@drawable/ic_nothing_found_120"
            android:contentDescription="@string/nothing_found" />

        <TextView
            android:id="@+id/tv_comment"
            style="@style/PlaceholderTextView"
            android:text="@string/empty_selected_tracks" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:visibility="gone"
        android:id="@+id/recycler_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</LinearLayout>